# Copie este arquivo para ".env" se quiser personalizar seu ambiente.
# Ele é opcional. A POC funciona apenas com o config.yaml, desde que as
# dependências estejam instaladas.

# Diretório de cache do Hugging Face.
HF_HOME=.cache/huggingface

# Token opcional para acesso a modelos privados ou com autenticação.
HF_TOKEN=

# Sobrescritas de configuração úteis.
DEVICE_MODE=auto
PERFORMANCE_PROFILE=auto
LOG_LEVEL=INFO

# Caminhos de saída, caso queira personalizar por máquina.
IMAGES_OUTPUT_DIR=outputs/images
VIDEOS_OUTPUT_DIR=outputs/videos
